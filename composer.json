{
    "name": "ronei-kunkel/webstract",
    "description": "The web abstraction package",
    "type": "library",
    "require-dev": {
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^13.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Webstract\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\": "test/",
            "Test\\Support\\": "test-support/"
        }
    },
    "authors": [
        {
            "name": "Ronei Kunkel",
            "email": "ronei.kunkel@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/container": "^2.0",
        "psr/log": "^3.0",
        "nikic/fast-route": "^1.3",
        "laminas/laminas-httphandlerrunner": "^2.13",
        "php-di/php-di": "^7.1",
        "aws/aws-sdk-php": "^3.377",
        "twig/twig": "^3.24",
        "nyholm/psr7-server": "^1.1",
        "nyholm/psr7": "^1.8",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.10",
        "guzzlehttp/guzzle": "^7.10"
    },
    "scripts": {
        "test": "vendor/bin/phpunit --testsuite Unit --exclude-group integration test --do-not-cache-result --no-progress --colors=never",
        "test:integration": "vendor/bin/phpunit --testsuite Integration --group integration --do-not-cache-result --no-progress --colors=never",
        "test:infra": "vendor/bin/phpunit --group infra --exclude-group integration --do-not-cache-result --no-progress --colors=never"
    }
}
